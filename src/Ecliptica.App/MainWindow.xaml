<Window x:Class="Ecliptica.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Ecliptica.Engine.ViewModels;assembly=Ecliptica.Engine"
        Title="Ecliptica" Height="650" Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource DeepSpaceBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Menu Bar — visible only in Simulation mode -->
        <Menu Grid.Row="0" Background="{StaticResource SpaceNavyBrush}" Foreground="{StaticResource StarWhiteBrush}" 
              BorderThickness="0,0,0,1" BorderBrush="{StaticResource BorderBrush}" Padding="4">
            <Menu.Style>
                <Style TargetType="Menu">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsSimulationActive}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Menu.Style>
            <Menu.Resources>
                <Style TargetType="MenuItem">
                    <Setter Property="Foreground" Value="{StaticResource StarWhiteBrush}"/>
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Padding" Value="8,4"/>
                </Style>
            </Menu.Resources>
            <MenuItem Header="File">
                <MenuItem Header="Save Project" Command="{Binding SimulationVM.SaveCommand}" Foreground="Black"/>
                <Separator/>
                <MenuItem Header="Exit Workspace" Command="{Binding SimulationVM.ExitCommand}" Foreground="Black"/>
            </MenuItem>
            <MenuItem Header="View">
                <MenuItem Header="Simulation Controls" IsCheckable="true" IsChecked="{Binding SimulationVM.IsControlsVisible}" Foreground="Black"/>
                <MenuItem Header="Energy Monitor" IsCheckable="true" IsChecked="{Binding SimulationVM.IsEnergyVisible}" Foreground="Black"/>
                <MenuItem Header="Performance Monitor" IsCheckable="true" IsChecked="{Binding SimulationVM.IsPerformanceVisible}" Foreground="Black"/>
                <MenuItem Header="Add Body Toolbox" IsCheckable="true" IsChecked="{Binding SimulationVM.IsAddBodyVisible}" Foreground="Black"/>
                <MenuItem Header="Body Inspector" IsCheckable="true" IsChecked="{Binding SimulationVM.IsInspectorVisible}" Foreground="Black"/>
                <MenuItem Header="Scientific Insights" IsCheckable="true" IsChecked="{Binding SimulationVM.IsInsightsVisible}" Foreground="Black"/>
            </MenuItem>
            <MenuItem Header="Run">
                <MenuItem Header="Play" Command="{Binding SimulationVM.PlayCommand}" Foreground="Black"/>
                <MenuItem Header="Pause" Command="{Binding SimulationVM.PauseCommand}" Foreground="Black"/>
                <MenuItem Header="Step" Command="{Binding SimulationVM.StepCommand}" Foreground="Black"/>
                <MenuItem Header="Reset" Command="{Binding SimulationVM.ResetSimulationCommand}" Foreground="Black"/>
            </MenuItem>
            <MenuItem Header="Help">
                <MenuItem Header="About Ecliptica" Foreground="Black"/>
            </MenuItem>
        </Menu>

        <!-- Content Area — swaps between views -->
        <ContentControl Grid.Row="1" Content="{Binding CurrentView}"/>

        <!-- Bottom Toolbar — visible only in Simulation mode -->
        <Border Grid.Row="2" Background="{StaticResource SpaceNavyBrush}" BorderThickness="0,1,0,0" 
                BorderBrush="{StaticResource BorderBrush}" Padding="10,6">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsSimulationActive}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Left: Mode buttons + active badge -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- ADD mode -->
                    <Button Width="65" Margin="0,0,4,0"
                            Command="{Binding SimulationVM.EnterAddModeCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource StandardButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SimulationVM.IsAddMode}" Value="True">
                                        <Setter Property="Background" Value="#1F3A5F"/>
                                        <Setter Property="BorderBrush" Value="{StaticResource AccentBlueBrush}"/>
                                        <Setter Property="Foreground" Value="{StaticResource AccentBlueBrush}"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <TextBlock Text="+ ADD"/>
                    </Button>
                    <!-- EDIT mode -->
                    <Button Width="65" Margin="0,0,4,0"
                            Command="{Binding SimulationVM.EnterEditModeCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource StandardButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SimulationVM.IsEditMode}" Value="True">
                                        <Setter Property="Background" Value="#1F3A5F"/>
                                        <Setter Property="BorderBrush" Value="{StaticResource AccentBlueBrush}"/>
                                        <Setter Property="Foreground" Value="{StaticResource AccentBlueBrush}"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <TextBlock Text="✏ EDIT"/>
                    </Button>
                    <!-- SIMULATE mode -->
                    <Button Width="80" Margin="0,0,4,0"
                            Command="{Binding SimulationVM.EnterSimulateModeCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource StandardButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SimulationVM.IsSimulateMode}" Value="True">
                                        <Setter Property="Background" Value="#1A3D2B"/>
                                        <Setter Property="BorderBrush" Value="#56D364"/>
                                        <Setter Property="Foreground" Value="#56D364"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <TextBlock Text="▶ SIMULATE"/>
                    </Button>
                    <!-- ANALYSE mode -->
                    <Button Width="75" Margin="0,0,10,0"
                            Command="{Binding SimulationVM.EnterAnalyseModeCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource StandardButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SimulationVM.IsAnalyseMode}" Value="True">
                                        <Setter Property="Background" Value="#2D1F5F"/>
                                        <Setter Property="BorderBrush" Value="{StaticResource GlowPurpleBrush}"/>
                                        <Setter Property="Foreground" Value="{StaticResource GlowPurpleBrush}"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <TextBlock Text="📊 ANALYSE"/>
                    </Button>

                    <!-- Mode badge -->
                    <Border Padding="8,2" VerticalAlignment="Center"
                            Background="#21262D" BorderThickness="1" CornerRadius="3">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SimulationVM.IsAddMode}" Value="True">
                                        <Setter Property="BorderBrush" Value="{StaticResource AccentBlueBrush}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding SimulationVM.IsSimulateMode}" Value="True">
                                        <Setter Property="BorderBrush" Value="#56D364"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding SimulationVM.IsAnalyseMode}" Value="True">
                                        <Setter Property="BorderBrush" Value="{StaticResource GlowPurpleBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock FontSize="10" FontWeight="Bold" Foreground="{StaticResource MutedTextBrush}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="MODE: IDLE"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SimulationVM.IsAddMode}" Value="True">
                                            <Setter Property="Text" Value="MODE: ADD"/>
                                            <Setter Property="Foreground" Value="{StaticResource AccentBlueBrush}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding SimulationVM.IsEditMode}" Value="True">
                                            <Setter Property="Text" Value="MODE: EDIT"/>
                                            <Setter Property="Foreground" Value="{StaticResource StarWhiteBrush}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding SimulationVM.IsSimulateMode}" Value="True">
                                            <Setter Property="Text" Value="MODE: SIMULATE"/>
                                            <Setter Property="Foreground" Value="#56D364"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding SimulationVM.IsAnalyseMode}" Value="True">
                                            <Setter Property="Text" Value="MODE: ANALYSE"/>
                                            <Setter Property="Foreground" Value="{StaticResource GlowPurpleBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Border>
                </StackPanel>

                <!-- Center: Time scale presets -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="Time Scale:" VerticalAlignment="Center" Margin="0,0,8,0"
                               Foreground="{StaticResource MutedTextBrush}" FontSize="11"/>
                    <Button Content="0.1×" Command="{Binding SimulationVM.SetTimeSpeedPresetCommand}" CommandParameter="0.1"
                            Style="{StaticResource StandardButtonStyle}" Margin="0,0,3,0"/>
                    <Button Content="1×" Command="{Binding SimulationVM.SetTimeSpeedPresetCommand}" CommandParameter="1.0"
                            Style="{StaticResource StandardButtonStyle}" Margin="0,0,3,0"/>
                    <Button Content="10×" Command="{Binding SimulationVM.SetTimeSpeedPresetCommand}" CommandParameter="10.0"
                            Style="{StaticResource StandardButtonStyle}" Margin="0,0,3,0"/>
                    <Button Content="100×" Command="{Binding SimulationVM.SetTimeSpeedPresetCommand}" CommandParameter="100.0"
                            Style="{StaticResource StandardButtonStyle}" Margin="0,0,8,0"/>
                    <Slider Width="120" Minimum="0.1" Maximum="100.0" Value="{Binding SimulationVM.TimeScale}"
                            VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding SimulationVM.TimeScale, StringFormat={}{0:F1}x}"
                               FontFamily="Consolas" FontSize="10" VerticalAlignment="Center"
                               Foreground="{StaticResource AccentBlueBrush}" Margin="6,0,0,0" Width="35"/>
                </StackPanel>

                <!-- Right: Panel visibility toggles -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <ToggleButton Content="Controls" IsChecked="{Binding SimulationVM.IsControlsVisible}"
                                  Style="{StaticResource {x:Type ToggleButton}}" Margin="0,0,3,0" Padding="6,2"/>
                    <ToggleButton Content="Energy" IsChecked="{Binding SimulationVM.IsEnergyVisible}"
                                  Style="{StaticResource {x:Type ToggleButton}}" Margin="0,0,3,0" Padding="6,2"/>
                    <ToggleButton Content="Perf" IsChecked="{Binding SimulationVM.IsPerformanceVisible}"
                                  Style="{StaticResource {x:Type ToggleButton}}" Margin="0,0,3,0" Padding="6,2"/>
                    <ToggleButton Content="Add Body" IsChecked="{Binding SimulationVM.IsAddBodyVisible}"
                                  Style="{StaticResource {x:Type ToggleButton}}" Margin="0,0,3,0" Padding="6,2"/>
                    <ToggleButton Content="Inspector" IsChecked="{Binding SimulationVM.IsInspectorVisible}"
                                  Style="{StaticResource {x:Type ToggleButton}}" Margin="0,0,3,0" Padding="6,2"/>
                    <ToggleButton Content="Insights" IsChecked="{Binding SimulationVM.IsInsightsVisible}"
                                  Style="{StaticResource {x:Type ToggleButton}}" Margin="0,0,3,0" Padding="6,2"/>
                    <ToggleButton Content="Log" IsChecked="{Binding SimulationVM.IsEventLogVisible}"
                                  Style="{StaticResource {x:Type ToggleButton}}" Padding="6,2"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
