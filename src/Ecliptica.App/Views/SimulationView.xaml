<UserControl x:Class="Ecliptica.App.Views.SimulationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:wf="clr-namespace:System.Windows.Forms.Integration;assembly=WindowsFormsIntegration"
             xmlns:r="clr-namespace:Ecliptica.Renderer;assembly=Ecliptica.Renderer"
             xmlns:ctrl="clr-namespace:Ecliptica.App.Controls"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="1200">
    <Grid Background="{StaticResource DeepSpaceBrush}">
        <!-- Viewport in background (fills the screen) -->
        <wf:WindowsFormsHost x:Name="ViewportHost">
            <r:SimulationViewport x:Name="GLViewport"/>
        </wf:WindowsFormsHost>

        <!-- Hidden layout grid for placement anchors -->
        <Grid x:Name="AnchorGrid" IsHitTestVisible="False">
            <FrameworkElement x:Name="LeftTopAnchor" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="15,15,0,0"/>
            <FrameworkElement x:Name="LeftBottomAnchor" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="15,0,0,15"/>
            <FrameworkElement x:Name="TopCenterAnchor" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,15,0,0"/>
            <FrameworkElement x:Name="CenterAnchor" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,80,0,0"/>
            <FrameworkElement x:Name="RightTopAnchor" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,15,15,0"/>
            <FrameworkElement x:Name="RightMidAnchor" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,270,15,0"/>
        </Grid>

        <!-- ====================================================
             PANEL 1 — Simulation Controls (Left Top)
             ==================================================== -->
        <Popup x:Name="ControlsPopup" IsOpen="{Binding IsControlsVisible}"
               PlacementTarget="{Binding ElementName=LeftTopAnchor}"
               Placement="Center" AllowsTransparency="True" PopupAnimation="None">
            <Border Width="295" Background="#F00D1117" BorderBrush="#2A2E35" BorderThickness="1" Padding="10">
                <StackPanel>
                    <Grid Margin="0,0,0,6">
                        <TextBlock Text="▼ Simulation Controls" Foreground="{StaticResource StarWhiteBrush}" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                        <Ellipse Width="8" Height="8" HorizontalAlignment="Right" VerticalAlignment="Center" Fill="{Binding IsPlaying, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="#8B949E"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsPlaying}" Value="True">
                                            <Setter Property="Fill" Value="#56D364"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                    </Grid>

                    <TextBlock Text="{Binding StabilityState, StringFormat='State: {0}'}" FontSize="10" Foreground="#56D364" Margin="0,0,0,8"/>

                    <!-- Action Row -->
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="4"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="4"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="4"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="Pause" Command="{Binding PauseCommand}" Style="{StaticResource StandardButtonStyle}" Padding="1"/>
                        <Button Grid.Column="2" Content="Stop" Command="{Binding PauseCommand}" Style="{StaticResource StandardButtonStyle}" Padding="1"/>
                        <Button Grid.Column="4" Content="Step" Command="{Binding StepCommand}" Style="{StaticResource StandardButtonStyle}" Padding="1"/>
                        <Button Grid.Column="6" Content="Reset" Command="{Binding ResetSimulationCommand}" Style="{StaticResource DangerButtonStyle}" Padding="1"/>
                    </Grid>

                    <!-- Follow and central body selections -->
                    <CheckBox Content="Follow Selected Body" IsChecked="{Binding FollowSelectedBody}" Margin="0,0,0,6" Foreground="{StaticResource StarWhiteBrush}"/>
                    <TextBlock Text="Orbit Reference Body" FontSize="10" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,3"/>
                    <CheckBox Content="Auto Central Body" IsChecked="{Binding AutoCentralBody}" Margin="0,0,0,6" Foreground="{StaticResource StarWhiteBrush}"/>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="6"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <ComboBox Grid.Column="0" ItemsSource="{Binding CentralBodies}" SelectedItem="{Binding SelectedCentralBody}" Height="22"/>
                        <ComboBox Grid.Column="2" ItemsSource="{Binding ReferenceFrames}" SelectedItem="{Binding SelectedReferenceFrame}" Height="22"/>
                    </Grid>

                    <Separator/>

                    <CheckBox Content="Show Predicted Trajectory" IsChecked="{Binding ShowPredictedTrajectory}" Margin="0,4,0,4" Foreground="{StaticResource StarWhiteBrush}"/>
                    <CheckBox Content="High Precision Prediction" IsChecked="{Binding HighPrecisionPrediction}" Margin="0,0,0,6" Foreground="{StaticResource StarWhiteBrush}"/>

                    <!-- Sim timings readout -->
                    <TextBlock Text="{Binding ElapsedTimeFormatted, StringFormat='Sim Time: {0}'}" FontFamily="Consolas" FontSize="10" Foreground="{StaticResource StarWhiteBrush}" Margin="0,0,0,2"/>
                    <TextBlock Text="{Binding TimeStepDt, StringFormat='Time Step (dt): {0:E3}'}" FontFamily="Consolas" FontSize="10" Foreground="{StaticResource StarWhiteBrush}" Margin="0,0,0,2"/>
                    <TextBlock Text="{Binding EffectiveDt, StringFormat='Effective dt: {0:E3}'}" FontFamily="Consolas" FontSize="10" Foreground="{StaticResource StarWhiteBrush}" Margin="0,0,0,2"/>
                    <TextBlock Text="{Binding SolverPath, StringFormat='Solver Path: {0}'}" FontFamily="Consolas" FontSize="10" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,4"/>

                    <TextBlock Text="Stability: Stable (100% dt)" FontSize="10" FontWeight="Bold" Foreground="#56D364" Margin="0,0,0,6"/>

                    <Separator/>

                    <!-- Checks matched to reference -->
                    <CheckBox Content="Orbital Trails" IsChecked="{Binding ShowTrails}" Margin="0,4,0,3" Foreground="{StaticResource StarWhiteBrush}"/>
                    <CheckBox Content="Persistent Orbit Paths" IsChecked="{Binding ShowPersistentOrbitPaths}" Margin="0,0,0,3" Foreground="{StaticResource StarWhiteBrush}"/>
                    <CheckBox Content="Accretion Disks" IsChecked="{Binding ShowAccretionDisks}" Margin="0,0,0,3" Foreground="{StaticResource StarWhiteBrush}"/>
                    <CheckBox Content="Gravitational Wave Visuals" IsChecked="{Binding ShowGravitationalWaves}" Margin="0,0,0,3" Foreground="{StaticResource StarWhiteBrush}"/>
                    <CheckBox Content="Bloom" IsChecked="{Binding ShowBloom}" Margin="0,0,0,3" Foreground="{StaticResource StarWhiteBrush}"/>
                    <CheckBox Content="HDR" IsChecked="{Binding ShowHdr}" Margin="0,0,0,3" Foreground="{StaticResource StarWhiteBrush}"/>
                    <CheckBox Content="Reflections (SSR-like)" IsChecked="{Binding ShowReflections}" Margin="0,0,0,3" Foreground="{StaticResource StarWhiteBrush}"/>
                    <CheckBox Content="Distance Glow Scaling" IsChecked="{Binding ShowGlow}" Margin="0,0,0,3" Foreground="{StaticResource StarWhiteBrush}"/>
                    <CheckBox Content="Cinematic Explosions" IsChecked="{Binding ShowExplosions}" Margin="0,0,0,3" Foreground="{StaticResource StarWhiteBrush}"/>
                    <CheckBox Content="Space Background" IsChecked="{Binding ShowSpaceBackground}" Margin="0,0,0,8" Foreground="{StaticResource StarWhiteBrush}"/>

                    <!-- Visual tuning sliders -->
                    <Grid Margin="0,0,0,4">
                        <TextBlock Text="Trail Length" FontSize="10" Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center"/>
                        <Slider Minimum="5" Maximum="100" Value="{Binding TrailLength}" Width="150" HorizontalAlignment="Right"/>
                    </Grid>
                    <Grid Margin="0,0,0,4">
                        <TextBlock Text="Orbit Path Long" FontSize="10" Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center"/>
                        <Slider Minimum="10" Maximum="2000" Value="{Binding OrbitPathLength}" Width="150" HorizontalAlignment="Right"/>
                    </Grid>
                    <Grid Margin="0,0,0,4">
                        <TextBlock Text="Trail Spacing" FontSize="10" Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center"/>
                        <Slider Minimum="0.0001" Maximum="0.01" Value="{Binding TrailSpacing}" Width="150" HorizontalAlignment="Right"/>
                    </Grid>
                    <Grid Margin="0,0,0,6">
                        <TextBlock Text="Orbit Path Spac" FontSize="10" Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center"/>
                        <Slider Minimum="0.0001" Maximum="0.01" Value="{Binding OrbitPathSpacing}" Width="150" HorizontalAlignment="Right"/>
                    </Grid>

                    <!-- Collapsible Event Log section -->
                    <Expander Header="Event Log" Foreground="{StaticResource StarWhiteBrush}" FontSize="10">
                        <ListBox ItemsSource="{Binding EventLog}" Height="70" Background="#161B22" BorderBrush="{StaticResource BorderBrush}" Margin="0,4,0,0"
                                 FontFamily="Consolas" FontSize="9">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" TextWrapping="Wrap" Foreground="{StaticResource MutedTextBrush}"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Expander>
                </StackPanel>
            </Border>
        </Popup>

        <!-- ====================================================
             PANEL 2 — Energy Monitor & Integrator (Top Center)
             ==================================================== -->
        <Popup x:Name="EnergyPopup" IsOpen="{Binding IsEnergyVisible}"
               PlacementTarget="{Binding ElementName=TopCenterAnchor}"
               Placement="Center" AllowsTransparency="True" PopupAnimation="None">
            <Border Width="305" Background="#F00D1117" BorderBrush="#2A2E35" BorderThickness="1" Padding="10">
                <StackPanel>
                    <TextBlock Text="▼ Energy Monitor" Foreground="{StaticResource StarWhiteBrush}" FontSize="11" FontWeight="Bold" Margin="0,0,0,8"/>

                    <TextBlock Text="{Binding KineticEnergy, StringFormat='Kinetic Energy:  {0:E6}'}" FontFamily="Consolas" FontSize="10" Foreground="#58A6FF" Margin="0,0,0,2"/>
                    <TextBlock Text="{Binding PotentialEnergy, StringFormat='Potential Energy: {0:E6}'}" FontFamily="Consolas" FontSize="10" Foreground="#FF6B6B" Margin="0,0,0,6"/>

                    <Separator/>

                    <TextBlock Text="{Binding TotalEnergy, StringFormat='Total Energy:     {0:E6}'}" FontFamily="Consolas" FontSize="10" Foreground="#BC8CFF" Margin="0,4,0,2"/>
                    <TextBlock Text="{Binding EnergyDrift, StringFormat='Energy Drift:     {0:F4}%'}" FontFamily="Consolas" FontSize="10" Foreground="#56D364" Margin="0,0,0,2"/>
                    <TextBlock Text="System Stability: Stable" FontFamily="Consolas" FontSize="10" Foreground="#56D364" Margin="0,0,0,6"/>

                    <Separator/>

                    <TextBlock Text="{Binding TotalMomentum, StringFormat='Total Momentum:   {0:E6}'}" FontFamily="Consolas" FontSize="10" Foreground="{StaticResource StarWhiteBrush}" Margin="0,4,0,2"/>
                    <TextBlock Text="{Binding MomentumDriftPercent, StringFormat='Momentum Drift:   {0:F4}%'}" FontFamily="Consolas" FontSize="10" Foreground="{StaticResource StarWhiteBrush}" Margin="0,0,0,2"/>
                    <TextBlock Text="{Binding CollisionsCount, StringFormat='Collisions (step): {0}'}" FontFamily="Consolas" FontSize="10" Foreground="{StaticResource StarWhiteBrush}" Margin="0,0,0,2"/>
                    <TextBlock Text="{Binding ExplosionBurstsCount, StringFormat='Explosion Bursts: {0}'}" FontFamily="Consolas" FontSize="10" Foreground="{StaticResource StarWhiteBrush}" Margin="0,0,0,6"/>

                    <Separator/>

                    <!-- Integrator selection nested here -->
                    <Grid Margin="0,4,0,4">
                        <TextBlock Text="Integrator:" FontSize="10" Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center"/>
                        <ComboBox SelectedIndex="0" HorizontalAlignment="Right" Width="190" Height="22">
                            <ComboBoxItem Content="Verlet (Symplectic)" Foreground="Black"/>
                            <ComboBoxItem Content="Euler-Cromer" Foreground="Black"/>
                            <ComboBoxItem Content="Runge-Kutta 4 (RK4)" Foreground="Black"/>
                        </ComboBox>
                    </Grid>
                    <TextBlock Text="{Binding IntegratorDescription}" FontSize="9" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" Margin="0,0,0,8"/>

                    <Separator/>

                    <!-- Graph representation box -->
                    <Border Background="#161B22" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="6" Height="40" Margin="0,4,0,0">
                        <TextBlock Text="{Binding TotalEnergyHistoryString}" FontFamily="Consolas" FontSize="11" Foreground="#56D364" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </StackPanel>
            </Border>
        </Popup>

        <!-- ====================================================
             PANEL 3 — Simulation Insights (Center Bottom)
             ==================================================== -->
        <Popup x:Name="InsightsPopup" IsOpen="{Binding IsInsightsVisible}"
               PlacementTarget="{Binding ElementName=CenterAnchor}"
               Placement="Center" AllowsTransparency="True" PopupAnimation="None">
            <Border Width="305" Background="#F00D1117" BorderBrush="#2A2E35" BorderThickness="1" Padding="10">
                <StackPanel>
                    <TextBlock Text="▼ Simulation Insights" Foreground="{StaticResource StarWhiteBrush}" FontSize="11" FontWeight="Bold" Margin="0,0,0,6"/>
                    <TextBlock Text="Select a body to enable scientific insights." FontSize="10" Foreground="{StaticResource MutedTextBrush}"
                               Visibility="{Binding SelectedBody, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Inverse}" TextWrapping="Wrap"/>
                    <StackPanel Visibility="{Binding SelectedBody, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="{Binding SelectedBody.Name, StringFormat='Entity: {0}'}" FontSize="10" Foreground="{StaticResource AccentBlueBrush}" FontWeight="Bold" Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding EscapeVelocity, StringFormat='Escape Velocity:   {0:F2} m/s'}" FontFamily="Consolas" FontSize="10" Foreground="{StaticResource StarWhiteBrush}" Margin="0,0,0,2"/>
                        <TextBlock Text="{Binding HillSphere, StringFormat='Hill Sphere Rad:   {0:E3} m'}" FontFamily="Consolas" FontSize="10" Foreground="{StaticResource StarWhiteBrush}" Margin="0,0,0,2"/>
                        <TextBlock Text="{Binding SchwarzschildRadius, StringFormat='Schwarzschild r:   {0:F1} m'}" FontFamily="Consolas" FontSize="10" Foreground="{StaticResource GlowPurpleBrush}" Margin="0,0,0,2"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Popup>

        <!-- ====================================================
             PANEL 4 — Add Body (Right Top)
             ==================================================== -->
        <Popup x:Name="AddBodyPopup" IsOpen="{Binding IsAddBodyVisible}"
               PlacementTarget="{Binding ElementName=RightTopAnchor}"
               Placement="Center" AllowsTransparency="True" PopupAnimation="None">
            <Border Width="290" Background="#F00D1117" BorderBrush="#2A2E35" BorderThickness="1" Padding="10">
                <StackPanel>
                    <TextBlock Text="▼ Add Body" Foreground="{StaticResource StarWhiteBrush}" FontSize="11" FontWeight="Bold" Margin="0,0,0,8"/>

                    <TextBlock Text="Category:" FontSize="10" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,3"/>
                    <ComboBox ItemsSource="{Binding AddCategories}" SelectedItem="{Binding SelectedAddCategory}" Height="22" Margin="0,0,0,6"/>

                    <TextBlock Text="Celestial Object:" FontSize="10" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,3"/>
                    <ComboBox ItemsSource="{Binding CelestialObjects}" SelectedItem="{Binding SelectedCelestialObject}" Height="22" Margin="0,0,0,8"/>

                    <TextBlock Text="Objects from Planets and Planetary Bodies." FontSize="9" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,6"/>

                    <TextBlock Text="Placement Mode:" FontSize="10" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,3"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <RadioButton Content="Manual" IsChecked="{Binding PlacementModeInteractive, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Inverse}" Foreground="{StaticResource StarWhiteBrush}" Margin="0,0,15,0"/>
                        <RadioButton Content="Interactive" IsChecked="{Binding PlacementModeInteractive}" Foreground="{StaticResource StarWhiteBrush}"/>
                    </StackPanel>

                    <TextBlock Text="Interactive placement: left click to anchor, drag to define velocity vector, release left mouse to commit." FontSize="9" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" Margin="0,0,0,8"/>

                    <!-- Sliders matching reference -->
                    <Grid Margin="0,0,0,4">
                        <TextBlock Text="Speed Scale" FontSize="10" Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center"/>
                        <Slider Minimum="0" Maximum="2" Value="{Binding SpeedScale}" Width="150" HorizontalAlignment="Right"/>
                    </Grid>
                    <Grid Margin="0,0,0,4">
                        <TextBlock Text="Min Speed" FontSize="10" Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center"/>
                        <Slider Minimum="0" Maximum="10" Value="{Binding MinSpeed}" Width="150" HorizontalAlignment="Right"/>
                    </Grid>
                    <Grid Margin="0,0,0,8">
                        <TextBlock Text="Max Speed" FontSize="10" Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center"/>
                        <Slider Minimum="1" Maximum="20" Value="{Binding MaxSpeed}" Width="150" HorizontalAlignment="Right"/>
                    </Grid>

                    <Separator/>

                    <!-- Placement State readouts -->
                    <TextBlock Text="Placement State: Idle" FontSize="10" Foreground="{StaticResource StarWhiteBrush}" Margin="0,4,0,2"/>
                    <TextBlock Text="{Binding VectorMagnitude, StringFormat='Vector magnitude: {0:F3}'}" FontFamily="Consolas" FontSize="10" Foreground="{StaticResource StarWhiteBrush}" Margin="0,0,0,2"/>
                    <TextBlock Text="{Binding DirectionVectorString, StringFormat='Direction: {0}'}" FontFamily="Consolas" FontSize="10" Foreground="{StaticResource StarWhiteBrush}" Margin="0,0,0,8"/>

                    <Button Content="Cancel Placement" Command="{Binding CancelPlacementCommand}" Style="{StaticResource DangerButtonStyle}" HorizontalAlignment="Stretch"/>
                </StackPanel>
            </Border>
        </Popup>

        <!-- ====================================================
             PANEL 5 — Body Inspector (Right Mid)
             ==================================================== -->
        <Popup x:Name="InspectorPopup" IsOpen="{Binding IsInspectorVisible}"
               PlacementTarget="{Binding ElementName=RightMidAnchor}"
               Placement="Center" AllowsTransparency="True" PopupAnimation="None">
            <Border Width="290" Background="#F00D1117" BorderBrush="#2A2E35" BorderThickness="1" Padding="10">
                <StackPanel>
                    <TextBlock Text="▼ Body Inspector" Foreground="{StaticResource StarWhiteBrush}" FontSize="11" FontWeight="Bold" Margin="0,0,0,6"/>

                    <!-- Body List -->
                    <ListBox Height="90" ItemsSource="{Binding Bodies}" SelectedItem="{Binding SelectedBody}"
                             DisplayMemberPath="Name" Margin="0,0,0,8"/>

                    <!-- Selected body details -->
                    <StackPanel Visibility="{Binding SelectedBody, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Border BorderThickness="0,1,0,0" BorderBrush="{StaticResource BorderBrush}" Padding="0,6,0,0">
                            <StackPanel>
                                <Grid Margin="0,0,0,6">
                                    <TextBlock Text="{Binding SelectedBody.Name}" FontWeight="SemiBold" Foreground="{StaticResource StarWhiteBrush}" VerticalAlignment="Center"/>
                                    <Border HorizontalAlignment="Right" Padding="4,1" CornerRadius="3" Background="#21262D" BorderBrush="{StaticResource AccentBlueBrush}" BorderThickness="1">
                                        <TextBlock Text="{Binding SelectedBody.BodyType}" FontSize="10" Foreground="{StaticResource AccentBlueBrush}"/>
                                    </Border>
                                </Grid>

                                <TextBlock Text="{Binding SelectedBody.Mass, StringFormat='Mass:    {0:E3} kg'}" FontFamily="Consolas" FontSize="10" Foreground="{StaticResource StarWhiteBrush}" Margin="0,0,0,2"/>
                                <TextBlock Text="{Binding SelectedBody.Radius, StringFormat='Radius:  {0:E3} m'}" FontFamily="Consolas" FontSize="10" Foreground="{StaticResource StarWhiteBrush}" Margin="0,0,0,2"/>
                                <TextBlock Text="{Binding SelectedBody.Velocity.Length, StringFormat='Speed:   {0:F2} m/s'}" FontFamily="Consolas" FontSize="10" Foreground="{StaticResource AccentBlueBrush}" Margin="0,0,0,6"/>

                                <TabControl Height="100">
                                    <TabItem Header="Thermodynamics">
                                        <StackPanel Margin="0,4,0,0" Visibility="{Binding SelectedBody.Thermodynamics, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <TextBlock Text="{Binding SelectedBody.Thermodynamics.Temperature, StringFormat='Temp: {0:F0} K'}" FontSize="10" Foreground="{StaticResource MutedTextBrush}"/>
                                            <TextBlock Text="{Binding SelectedBody.Thermodynamics.InternalEnergy, StringFormat='Energy: {0:E3} J'}" FontSize="10" Foreground="{StaticResource MutedTextBrush}"/>
                                            <TextBlock Text="{Binding SelectedBody.Thermodynamics.EnergyFluxIn, StringFormat='Flux In: {0:E3} W'}" FontSize="10" Foreground="{StaticResource MutedTextBrush}"/>
                                        </StackPanel>
                                    </TabItem>
                                    <TabItem Header="Stellar">
                                        <StackPanel Margin="0,4,0,0" Visibility="{Binding SelectedBody.Stellar, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <TextBlock Text="{Binding SelectedBody.Stellar.Phase, StringFormat='Phase: {0}'}" FontSize="10" Foreground="{StaticResource MutedTextBrush}"/>
                                            <TextBlock Text="{Binding SelectedBody.Stellar.Luminosity, StringFormat='Luminosity: {0:E3} W'}" FontSize="10" Foreground="{StaticResource MutedTextBrush}"/>
                                            <TextBlock Text="{Binding SelectedBody.Stellar.Age, StringFormat='Age: {0:E3} s'}" FontSize="10" Foreground="{StaticResource MutedTextBrush}"/>
                                        </StackPanel>
                                    </TabItem>
                                    <TabItem Header="Dark Matter">
                                        <StackPanel Margin="0,4,0,0" Visibility="{Binding SelectedBody.DarkMatter, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <TextBlock Text="{Binding SelectedBody.DarkMatter.HaloMass, StringFormat='Halo Mass: {0:E3} kg'}" FontSize="10" Foreground="{StaticResource MutedTextBrush}"/>
                                            <TextBlock Text="{Binding SelectedBody.DarkMatter.ScaleRadius, StringFormat='Scale Rad: {0:E3} m'}" FontSize="10" Foreground="{StaticResource MutedTextBrush}"/>
                                        </StackPanel>
                                    </TabItem>
                                </TabControl>

                                <Button Content="Delete Body" Command="{Binding DeleteBodyCommand}" Style="{StaticResource DangerButtonStyle}" HorizontalAlignment="Stretch" Margin="0,6,0,0"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Popup>

        <!-- ====================================================
             PANEL 6 — Performance (Left Bottom)
             ==================================================== -->
        <Popup x:Name="PerformancePopup" IsOpen="{Binding IsPerformanceVisible}"
               PlacementTarget="{Binding ElementName=LeftBottomAnchor}"
               Placement="Center" AllowsTransparency="True" PopupAnimation="None">
            <Border Width="295" Background="#F00D1117" BorderBrush="#2A2E35" BorderThickness="1" Padding="10">
                <StackPanel>
                    <TextBlock Text="▼ Performance" Foreground="{StaticResource StarWhiteBrush}" FontSize="11" FontWeight="Bold" Margin="0,0,0,6"/>

                    <TextBlock Text="{Binding Fps, StringFormat='FPS:       {0:F0}'}" FontFamily="Consolas" FontSize="10" Foreground="#56D364" Margin="0,0,0,2"/>
                    <TextBlock Text="{Binding BodyCount, StringFormat='Body Count: {0}'}" FontFamily="Consolas" FontSize="10" Foreground="{StaticResource StarWhiteBrush}" Margin="0,0,0,2"/>
                    <TextBlock Text="{Binding PhysicsTimeMs, StringFormat='Physics:    {0:F3} ms'}" FontFamily="Consolas" FontSize="10" Foreground="{StaticResource StarWhiteBrush}" Margin="0,0,0,2"/>
                    <TextBlock Text="{Binding RenderTimeMs, StringFormat='Render:     {0:F3} ms'}" FontFamily="Consolas" FontSize="10" Foreground="{StaticResource StarWhiteBrush}" Margin="0,0,0,2"/>
                    <TextBlock Text="Frame dt:   7.111 ms" FontFamily="Consolas" FontSize="10" Foreground="{StaticResource StarWhiteBrush}" Margin="0,0,0,6"/>

                    <!-- Frame Budget progress bar matching reference -->
                    <TextBlock Text="Frame Budget Usage:" FontSize="9" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,3"/>
                    <Grid Height="14" Background="#161B22">
                        <ProgressBar Value="8.8" Minimum="0" Maximum="100" Background="Transparent" Foreground="#58A6FF" BorderThickness="0"/>
                        <TextBlock Text="8.8%" FontSize="9" Foreground="{StaticResource StarWhiteBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Popup>

    </Grid>
</UserControl>
