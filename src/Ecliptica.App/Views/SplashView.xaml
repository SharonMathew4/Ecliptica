<UserControl x:Class="Ecliptica.App.Views.SplashView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Background="{StaticResource DeepSpaceBrush}">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <!-- Title -->
            <TextBlock Text="ECLIPTICA" 
                       Margin="0,0,0,10"
                       FontSize="48" 
                       HorizontalAlignment="Center"
                       Foreground="{StaticResource StarWhiteBrush}"
                       FontWeight="Bold">
                <TextBlock.Triggers>
                    <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                 From="0.0" To="1.0" Duration="0:0:1" />
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </TextBlock.Triggers>
            </TextBlock>

            <!-- Tagline -->
            <TextBlock Text="Celestial Simulation &amp; Observation" 
                       FontSize="16" 
                       Foreground="{StaticResource MutedTextBrush}"
                       HorizontalAlignment="Center">
                <TextBlock.Triggers>
                    <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                 From="0.0" To="1.0" BeginTime="0:0:0.5" Duration="0:0:0.8" />
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </TextBlock.Triggers>
            </TextBlock>

            <!-- Loading indicator -->
            <ProgressBar IsIndeterminate="True" 
                         Width="200" 
                         Height="4" 
                         Margin="0,30,0,0"
                         Background="#10ffffff"
                         Foreground="{StaticResource AccentBlueBrush}"
                         BorderThickness="0">
                <ProgressBar.Triggers>
                    <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                 From="0.0" To="1.0" BeginTime="0:0:0.8" Duration="0:0:0.5" />
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </ProgressBar.Triggers>
            </ProgressBar>
        </StackPanel>
    </Grid>
</UserControl>
