<Application x:Class="Ecliptica.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:v="clr-namespace:Ecliptica.App.Views"
             xmlns:vm="clr-namespace:Ecliptica.Engine.ViewModels;assembly=Ecliptica.Engine"
             Startup="OnStartup">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Themes/DarkTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Converters -->
            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

            <!-- DataTemplates mapping ViewModels to Views -->
            <DataTemplate DataType="{x:Type vm:SplashViewModel}">
                <v:SplashView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:ModeSelectionViewModel}">
                <v:ModeSelectionView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:ProjectPickerViewModel}">
                <v:ProjectPickerView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:SimulationViewModel}">
                <v:SimulationView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:ObservationViewModel}">
                <v:ObservationView/>
            </DataTemplate>
        </ResourceDictionary>
    </Application.Resources>
</Application>
